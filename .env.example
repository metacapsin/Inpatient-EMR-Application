# Stripe (required for embedded checkout: cards, UPI, QR)
# Use your PUBLISHABLE key (pk_test_...) here. Safe for frontend.
# NEVER put your SECRET key (sk_test_...) in this repo – use it only on your backend server.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Stripe Payment Links (optional - for redirect checkout without backend)
# Create Payment Links in Stripe Dashboard (test mode): Products → Payment Links
# IMPORTANT: In each Payment Link, set "After payment" → Success URL to your app so users
# are sent back to the dashboard instead of staying on Stripe's confirmation page:
#   Success URL: https://YOUR_DOMAIN/app/subscription/success
#   Cancel URL:  https://YOUR_DOMAIN/app/subscription?canceled=true

# Per-plan links (monthly/yearly for each plan)
VITE_STRIPE_LINK_BASIC_MONTHLY=https://buy.stripe.com/test_xxxxx
VITE_STRIPE_LINK_BASIC_YEARLY=https://buy.stripe.com/test_xxxxx
VITE_STRIPE_LINK_PREMIUM_MONTHLY=https://buy.stripe.com/test_xxxxx
VITE_STRIPE_LINK_PREMIUM_YEARLY=https://buy.stripe.com/test_xxxxx
VITE_STRIPE_LINK_FAMILY_MONTHLY=https://buy.stripe.com/test_xxxxx
VITE_STRIPE_LINK_FAMILY_YEARLY=https://buy.stripe.com/test_xxxxx

# Or use a single demo link for quick testing
VITE_STRIPE_DEMO_LINK=https://buy.stripe.com/test_xxxxx

# Subscription: omit or set to "true" to skip Stripe (Subscribe Now → dashboard). Set to "false" for real checkout.
# VITE_BYPASS_STRIPE_SUBSCRIPTION=false
